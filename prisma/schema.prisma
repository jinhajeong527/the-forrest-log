generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Prop {
  FOAM_ROLLER
  KNEE_PAD
  BLOCK
  STRAP
  BOLSTER
  BLANKET
}

enum PoseCategory {
  ABDOMINALS
  ARM_BALANCES
  BACKBENDS
  BALANCING_POSES
  FORWARD_BENDS
  INVERSIONS
  LUNGES
  SEATED
  STANDING_POSES
  SUPINE
  TWISTS
}

enum PoseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Pose {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  sanskritName String?        @map("sanskrit_name")
  categories   PoseCategory[]
  level        PoseLevel      @default(BEGINNER)
  description  String?
  imageUrl     String?        @map("image_url")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  practiceLogs PracticeLog[]  @relation("PeakPose")
  sequenceLogs SequenceLog[]

  @@map("poses")
}

model PracticeLog {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  date            DateTime      @db.Date
  theme           String?
  peakPoseId      String?       @map("peak_pose_id") @db.Uuid
  conditionBefore Int?          @map("condition_before")
  conditionAfter  Int?          @map("condition_after")
  props           Prop[]        @default([])
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  peakPose        Pose?         @relation("PeakPose", fields: [peakPoseId], references: [id])
  sequenceLogs    SequenceLog[]

  @@map("practice_logs")
}

model SequenceLog {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceLogId String      @map("practice_log_id") @db.Uuid
  poseId        String      @map("pose_id") @db.Uuid
  order         Int
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  practiceLog   PracticeLog @relation(fields: [practiceLogId], references: [id])
  pose          Pose        @relation(fields: [poseId], references: [id])

  @@index([practiceLogId, order])
  @@map("sequence_logs")
}
